{
  "name": "sanad-server",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "description": "a server to connect the rosbridge websocket to the outer system components",
  "main": "src/index.js",
  "imports": {
    "#utils/*": "./src/utils/*",
    "#lib/*": "./src/lib/*",
    "#src/*": "./src/*",
    "#modules/*": "./src/api/v1/*",
    "#core/*": "./src/core/*"
  },
  "scripts": {
    "dev": "tsc --watch src/index.ts",
    "test": "NODE_ENV=testing NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" npx jest --detectOpenHandles --runInBand --testTimeout=5000",
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanadChair/server.git"
  },
  "keywords": [
    "sanad",
    "server",
    "rosbridge",
    "roslibjs"
  ],
  "author": "OmarKHDR",
  "bugs": {
    "url": "https://github.com/sanadChair/server/issues"
  },
  "homepage": "https://github.com/sanadChair/server#readme",
  "dependencies": {
    "broadcast-address": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.1",
    "mqtt": "^5.15.0",
    "reflect-metadata": "^0.2.2",
    "roslib": "^1.4.1",
    "socket.io": "^4.8.1",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "winston": "^3.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/roslib": "^1.3.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10"
  },
  "nodemonConfig": {
    "ignore": [
      "src/mocks/smart-home/smart-dev.json",
      "src/api/v1/smart-home/smart-home.db.json"
    ]
  }
}
